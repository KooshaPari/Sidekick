# Sidekick — environment template (no secrets)
# Copy to .env and fill in values locally. Never commit .env.

# ── Logging / observability ──────────────────────────────────────────
RUST_LOG=sidekick-messaging=info,sidekick_obs_core=warn
SIDEKICK_LOG_LEVEL=info
SIDEKICK_LOG_JSON=true
CHEAP_LLM_LOG_LEVEL=INFO

# Health probe identity (sidekick-healthcheck CLI)
SIDEKICK_SERVICE=sidekick
SIDEKICK_VERSION=0.0.1
SIDEKICK_HEALTH_MODE=ready

# ── cheap-llm-mcp providers (required for LLM routing) ───────────────
MINIMAX_API_KEY=
MOONSHOT_API_KEY=
FIREWORKS_API_KEY=

# Optional: monthly spend cap (USD) — see config/cheap-llm.example.toml
# CHEAP_LLM_MONTHLY_CAP_USD=25.00
